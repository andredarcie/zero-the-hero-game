[application]

config/name="Zero the Hero"
run/main_scene="res://engine/Screens/TitleScreen.tscn"
boot_splash/bg_color=Color( 0, 0, 0, 1 )
config/icon="res://icon.png"

[autoload]

dir="*res://engine/directions.gd"
GameState="*res://engine/GameState.gd"
LevelManager="*res://levels_old/LevelManager.gd"
Helpers="*res://engine/Helpers.gd"
BackgroundMusic="*res://engine/Sounds/BackgroundMusic.tscn"
SoundEffects="*res://engine/Sounds/SoundEffects.tscn"
Hud="*res://ui/hud.tscn"

[display]

window/size/width=480
window/size/height=240
window/size/test_width=1440
window/size/test_height=720
window/dpi/allow_hidpi=true
window/stretch/mode="2d"
window/stretch/aspect="keep"

[global]

snap=false
scene=false
use_pixel_snap=false

[gui]

common/snap_controls_to_pixels=false
theme/snap_controls_to_pixels=true

[importer_defaults]

texture={
"compress/bptc_ldr": 0,
"compress/hdr_mode": 0,
"compress/lossy_quality": 0.7,
"compress/mode": 0,
"compress/normal_map": 0,
"detect_3d": false,
"flags/anisotropic": false,
"flags/filter": false,
"flags/mipmaps": false,
"flags/repeat": 0,
"flags/srgb": 2,
"process/HDR_as_SRGB": false,
"process/fix_alpha_border": true,
"process/invert_color": false,
"process/premult_alpha": false,
"size_limit": 0,
"stream": false,
"svg/scale": 1.0
}

